{% extends 'base.html.twig' %}

{% block title %}{{ site.name }} - Audit{% endblock %}

{% block body %}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('audit_index') }}">Audit</a></li>
        <li class="breadcrumb-item active">{{ site.name }}</li>
    </ol>
</nav>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}
{% for message in app.flashes('warning') %}
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">{{ site.name }}</h1>
        <code class="text-muted">{{ site.rootUrl }}</code>
        {% if site.prodUrl %}
            <a href="{{ site.prodUrl }}" target="_blank" rel="noopener" class="ms-2 text-decoration-none"><code>{{ site.prodUrl }}</code> <i class="fa-solid fa-up-right-from-square small"></i></a>
        {% endif %}
        {% if site.authType %}
            <span class="badge bg-warning text-dark ms-2"><i class="fa-solid fa-lock"></i> Protégé</span>
        {% endif %}
        {% if site.lastCrawledAt %}
            <span class="text-muted ms-2 small"><i class="fa-solid fa-spider"></i> {{ site.crawledPages }} pages crawlées</span>
        {% endif %}
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#editSiteModal" title="Modifier les informations du site">
            <i class="fa-solid fa-pen"></i> Modifier
        </button>
        <a href="{{ path('audit_auth', {id: site.id}) }}" class="btn btn-outline-warning btn-sm" title="Authentification">
            <i class="fa-solid fa-key"></i> Auth
        </a>
        <a href="{{ path('audit_crawl_manage', {id: site.id}) }}" class="btn btn-outline-secondary btn-sm" title="Gérer les pages crawlées">
            <i class="fa-solid fa-list"></i> Pages
        </a>
        {% if site.crawlStatus == 'completed' %}
            <a href="{{ path('audit_crawl_page', {id: site.id}) }}" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-rotate"></i> Recrawler
            </a>
            <form method="post" action="{{ path('audit_analyze', {id: site.id}) }}" class="d-inline">
                <button type="submit" class="btn btn-success btn-sm">
                    <i class="fa-solid fa-play"></i> Analyser
                </button>
            </form>
        {% elseif site.crawlStatus != 'running' %}
            <a href="{{ path('audit_crawl_page', {id: site.id}) }}" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-spider"></i> Crawler
            </a>
        {% else %}
            <span class="btn btn-outline-warning btn-sm disabled">
                <span class="spinner-border spinner-border-sm"></span> Crawl en cours
            </span>
        {% endif %}
        <form method="post" action="{{ path('audit_delete', {id: site.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce site et toutes ses analyses ?')">
            <button type="submit" class="btn btn-outline-danger btn-sm" title="Supprimer le site">
                <i class="fa-solid fa-trash"></i>
            </button>
        </form>
    </div>
</div>

{% if analyses is not empty %}
    {% set latestScores = null %}
    {% for analysis in analyses %}
        {% if analysis.status == 'completed' and analysisScores[analysis.id] is defined and latestScores is null %}
            {% set latestScores = analysisScores[analysis.id] %}
        {% endif %}
    {% endfor %}
    {% if latestScores %}
        <div class="row g-3 text-center mb-4">
            <div class="col">
                <div class="display-6 fw-bold {{ latestScores.rgaa >= 90 ? 'text-success' : latestScores.rgaa >= 50 ? 'text-warning' : 'text-danger' }}">{{ latestScores.rgaa }}</div>
                <div class="text-muted small">RGAA</div>
            </div>
            <div class="col">
                <div class="display-6 fw-bold {{ latestScores.a11y >= 90 ? 'text-success' : latestScores.a11y >= 50 ? 'text-warning' : 'text-danger' }}">{{ latestScores.a11y }}</div>
                <div class="text-muted small">A11y</div>
            </div>
            <div class="col">
                <div class="display-6 fw-bold {{ latestScores.perf >= 90 ? 'text-success' : latestScores.perf >= 50 ? 'text-warning' : 'text-danger' }}">{{ latestScores.perf }}</div>
                <div class="text-muted small">Perf</div>
            </div>
            <div class="col">
                <div class="display-6 fw-bold {{ latestScores.bp >= 90 ? 'text-success' : latestScores.bp >= 50 ? 'text-warning' : 'text-danger' }}">{{ latestScores.bp }}</div>
                <div class="text-muted small">BP</div>
            </div>
            <div class="col">
                <div class="display-6 fw-bold {{ latestScores.seo >= 90 ? 'text-success' : latestScores.seo >= 50 ? 'text-warning' : 'text-danger' }}">{{ latestScores.seo }}</div>
                <div class="text-muted small">SEO</div>
            </div>
        </div>
    {% endif %}

    <div class="card mb-4">
        <div class="card-header py-2">
            <h6 class="mb-0"><i class="fa-solid fa-chart-line"></i> Analyses</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0" id="analysesTable">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Statut</th>
                        <th class="text-center">Pages</th>
                        <th>Durée</th>
                        <th class="text-center">RGAA</th>
                        <th class="text-center">A11y</th>
                        <th class="text-center">Perf</th>
                        <th class="text-center">BP</th>
                        <th class="text-center">SEO</th>
                    </tr>
                </thead>
                <tbody>
                    {% set statusColors = {'completed': 'success', 'running': 'warning', 'failed': 'danger', 'cancelled': 'secondary', 'pending': 'secondary'} %}
                    {% set statusLabels = {'completed': 'Terminée', 'running': 'En cours', 'failed': 'Échouée', 'cancelled': 'Arrêtée', 'pending': 'En attente'} %}
                    {% macro scoreBadge(score) %}
                        {% if score is not null %}
                            {% set color = score >= 90 ? 'success' : (score >= 50 ? 'warning' : 'danger') %}
                            <span class="badge bg-{{ color }}" style="font-size:0.95em; padding:0.4em 0.7em;">{{ score }}</span>
                        {% else %}
                            <span class="text-muted">-</span>
                        {% endif %}
                    {% endmacro %}
                    {% for analysis in analyses %}
                        {% set scores = analysisScores[analysis.id] ?? null %}
                        <tr>
                            <td>
                                {% if analysis.status == 'running' %}
                                    <a href="{{ path('audit_analysis_progress', {id: analysis.id}) }}" class="text-decoration-none">{{ analysis.createdAt|date('d/m/Y H:i') }}</a>
                                {% else %}
                                    <a href="{{ path('audit_analysis', {id: analysis.id}) }}" class="text-decoration-none">{{ analysis.createdAt|date('d/m/Y H:i') }}</a>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge bg-{{ statusColors[analysis.status] ?? 'secondary' }}">
                                    {{ statusLabels[analysis.status] ?? analysis.status }}
                                </span>
                                {% if analysis.errorMessage %}
                                    <small class="text-danger d-block">{{ analysis.errorMessage }}</small>
                                {% endif %}
                            </td>
                            <td class="text-center">{{ analysis.pagesCrawled }}/{{ analysis.totalPages }}</td>
                            <td>{{ analysis.duration ?? '-' }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.rgaa ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.a11y ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.perf ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.bp ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.seo ?? null) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}

<div class="card mb-4">
    <div class="card-header py-2 d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#excludeSection" role="button">
        <h6 class="mb-0"><i class="fa-solid fa-ban"></i> Exclusions
            {% if site.excludePatterns is not empty %}
                <span class="badge bg-secondary ms-1">{{ site.excludePatterns|length }}</span>
            {% endif %}
        </h6>
        <i class="fa-solid fa-chevron-down small"></i>
    </div>
    <div class="collapse {{ site.excludePatterns is not empty ? 'show' : '' }}" id="excludeSection">
        <div class="card-body pt-0 pb-3">
            <form method="post" action="{{ path('audit_exclude', {id: site.id}) }}">
                <div id="exclude-patterns" class="mb-2"></div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="addExcludePattern()">
                        <i class="fa-solid fa-plus"></i> Ajouter
                    </button>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-save"></i> Enregistrer
                    </button>
                    {% if site.excludePatterns is not empty %}
                        <form method="post" action="{{ path('audit_exclude_clean', {id: site.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer toutes les pages correspondant aux règles d\'exclusion de TOUTES les analyses ?')">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="fa-solid fa-broom"></i> Appliquer
                            </button>
                        </form>
                    {% endif %}
                </div>
            </form>
        </div>
    </div>
</div>

<script>
let excludePatternIdx = 0;
const existingPatterns = {{ site.excludePatterns|json_encode|raw }};

function addExcludePattern(type, value) {
    type = type || 'starts_with';
    value = value || '';
    const container = document.getElementById('exclude-patterns');
    const row = document.createElement('div');
    row.className = 'input-group input-group-sm mb-1';
    row.innerHTML =
        '<select class="form-select form-select-sm" name="exclude_type[]" style="max-width:140px;">' +
            '<option value="starts_with"' + (type === 'starts_with' ? ' selected' : '') + '>Commence par</option>' +
            '<option value="contains"' + (type === 'contains' ? ' selected' : '') + '>Contient</option>' +
            '<option value="ends_with"' + (type === 'ends_with' ? ' selected' : '') + '>Finit par</option>' +
            '<option value="equals"' + (type === 'equals' ? ' selected' : '') + '>Égal à</option>' +
        '</select>' +
        '<input type="text" class="form-control form-control-sm" name="exclude_value[]" placeholder="/admin, /api" value="' + escHtml(value) + '">' +
        '<button type="button" class="btn btn-outline-danger btn-sm" onclick="this.parentElement.remove()"><i class="fa-solid fa-xmark"></i></button>';
    container.appendChild(row);
}

function escHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
}

document.addEventListener('DOMContentLoaded', function() {
    if (Array.isArray(existingPatterns)) {
        existingPatterns.forEach(function(p) {
            addExcludePattern(p.type, p.value);
        });
    }
});
</script>

<div class="modal fade" id="editSiteModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" action="{{ path('audit_site_edit', {id: site.id}) }}">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fa-solid fa-pen"></i> Modifier le site</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="edit_name" class="form-label">Nom</label>
                        <input type="text" class="form-control" id="edit_name" name="name" value="{{ site.name }}" required>
                    </div>
                    <div class="mb-3">
                        <label for="edit_root_url" class="form-label">URL racine</label>
                        <input type="url" class="form-control" id="edit_root_url" name="root_url" value="{{ site.rootUrl }}" required>
                        <div class="form-text">URL utilisée pour le crawl et l'analyse.</div>
                    </div>
                    <div class="mb-3">
                        <label for="edit_prod_url" class="form-label">URL PROD</label>
                        <input type="url" class="form-control" id="edit_prod_url" name="prod_url" value="{{ site.prodUrl ?? '' }}">
                        <div class="form-text">URL de production visible (pour référence uniquement).</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-primary"><i class="fa-solid fa-save"></i> Enregistrer</button>
                </div>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block localscript %}
<script>
    $(document).ready(function() {
        $('#analysesTable').DataTable({
            order: [[0, 'desc']],
            pageLength: 25,
            language: { lengthMenu: 'Afficher _MENU_ analyses' },
            searching: false
        });
    });
</script>
{% endblock %}
