            return '<div class="text-danger fw-bold"><i class="fa-solid fa-xmark-circle"></i> Lighthouse : ' + esc(line.substring(9)) + '</div>';
        }
        if (line.startsWith('ERROR_RGAA:')) {
            return '<div class="text-danger fw-bold"><i class="fa-solid fa-xmark-circle"></i> pa11y : ' + esc(line.substring(11)) + '</div>';
        }
        if (line.startsWith('ERROR:')) {
            return '<div class="text-danger fw-bold"><i class="fa-solid fa-xmark-circle"></i> ' + esc(line.substring(6)) + '</div>';
        }
        return '<div>' + esc(line) + '</div>';
    }

    (async function() {
        try {
            const response = await fetch('{{ path("audit_analysis_page_reanalyze", {id: analysis.id, reportId: report.id}) }}', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            if (!response.ok) {
                consoleEl.innerHTML += '<div class="text-danger">Erreur HTTP ' + response.status + '</div>';
                btn.disabled = false;
