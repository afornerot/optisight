{% extends 'base.html.twig' %}

{% block title %}Audit RGAA & SEO - {{ parent() }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Sites audités</h1>
    <a href="{{ path('audit_new') }}" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Ajouter un site
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% if sites is empty %}
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="fa-solid fa-globe fa-3x mb-3"></i>
            <p>Aucun site configuré. Ajoutez votre premier site pour commencer.</p>
        </div>
    </div>
{% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>URL</th>
                        <th class="text-center">RGAA</th>
                        <th class="text-center">A11y</th>
                        <th class="text-center">Perf</th>
                        <th class="text-center">BP</th>
                        <th class="text-center">SEO</th>
                        <th>Analyses</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for site in sites %}
                        <tr>
                            <td>
                                <a href="{{ path('audit_site', {id: site.id}) }}" class="text-decoration-none fw-bold">
                                    {{ site.name }}
                                </a>
                            </td>
                            <td><code>{{ site.rootUrl }}</code></td>
                            {% set scores = siteScores[site.id] ?? null %}
                            {% set labels = {'rgaa': 'RGAA', 'a11y': 'A11y', 'perf': 'Perf', 'bp': 'BP', 'seo': 'SEO'} %}
                            {% set order = ['rgaa', 'a11y', 'perf', 'bp', 'seo'] %}
                            {% for key in order %}
                                <td class="text-center">
                                    {% if scores and scores[key] is not null %}
                                        <span class="fw-bold {{ scores[key] >= 90 ? 'text-success' : scores[key] >= 50 ? 'text-warning' : 'text-danger' }}">{{ scores[key] }}</span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                            {% endfor %}
                            <td>{{ site.analyses|length }}</td>
                            <td class="text-end">
                                <a href="{{ path('audit_site', {id: site.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <form method="post" action="{{ path('audit_delete', {id: site.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce site et toutes ses analyses ?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
{% endblock %}
