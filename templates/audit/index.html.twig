{% extends 'base.html.twig' %}

{% block title %}Audit RGAA & SEO - {{ parent() }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Sites audités</h1>
    <a href="{{ path('audit_new') }}" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Ajouter un site
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% if sites is empty %}
    <div class="card">
        <div class="card-body text-center text-muted py-5">
            <i class="fa-solid fa-globe fa-3x mb-3"></i>
            <p>Aucun site configuré. Ajoutez votre premier site pour commencer.</p>
        </div>
    </div>
{% else %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="sitesTable">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>URL</th>
                        <th class="text-center">RGAA</th>
                        <th class="text-center">A11y</th>
                        <th class="text-center">Perf</th>
                        <th class="text-center">BP</th>
                        <th class="text-center">SEO</th>
                    </tr>
                </thead>
                <tbody>
                    {% for site in sites %}
                        <tr>
                            <td>
                                <a href="{{ path('audit_site', {id: site.id}) }}" class="text-decoration-none fw-bold">
                                    {{ site.name }}
                                </a>
                            </td>
                            <td><code>{{ site.rootUrl }}</code>{% if site.prodUrl %} <a href="{{ site.prodUrl }}" target="_blank" rel="noopener" class="text-decoration-none" title="PROD"><i class="fa-solid fa-up-right-from-square small"></i></a>{% endif %}</td>
                            {% set scores = siteScores[site.id] ?? null %}
                            {% macro scoreBadge(score) %}
                                {% if score is not null %}
                                    {% set color = score >= 90 ? 'success' : (score >= 50 ? 'warning' : 'danger') %}
                                    <span class="badge bg-{{ color }}" style="font-size:0.95em; padding:0.4em 0.7em;">{{ score }}</span>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            {% endmacro %}
                            <td class="text-center">{{ _self.scoreBadge(scores.rgaa ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.a11y ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.perf ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.bp ?? null) }}</td>
                            <td class="text-center">{{ _self.scoreBadge(scores.seo ?? null) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
{% endblock %}

{% block localscript %}
<script>
    $(document).ready(function() {
        $('#sitesTable').DataTable({
            order: [[0, 'asc']],
            pageLength: 25,
            language: { lengthMenu: 'Afficher _MENU_ sites' }
        });
    });
</script>
{% endblock %}
