{% extends 'base.html.twig' %}

{% block title %}Analyse RGAA - {{ site.name }}{% endblock %}

{% block body %}
<div style="height: calc(100vh - 56px); margin: -1rem; display: flex; flex-direction: column;">
    <div class="px-4 pt-3 pb-2">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="{{ path('audit_index') }}">Audit</a></li>
                <li class="breadcrumb-item"><a href="{{ path('audit_site', {id: site.id}) }}">{{ site.name }}</a></li>
                <li class="breadcrumb-item active">Analyse RGAA</li>
            </ol>
        </nav>
    </div>

    <div class="px-4 pb-4 flex-grow-1 d-flex flex-column" style="min-height: 0;">
        <div class="card d-flex flex-column" style="height: 100%; min-height: 0;">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <h6 class="mb-0"><i class="fa-solid fa-terminal"></i> Console — RGAA + Lighthouse</h6>
                <div>
                    <button class="btn btn-outline-danger btn-sm" id="btn-stop" onclick="stopAnalysis()" style="display: none;">
                        <i class="fa-solid fa-stop"></i> Arrêter
                    </button>
                    <span id="status-badge" class="badge bg-warning">En cours...</span>
                </div>
            </div>
            <div class="card-body p-0 d-flex flex-column" style="min-height: 0;">
                <div id="console-output" class="p-3 text-white bg-dark m-0" style="flex: 1 1 0; overflow-y: auto; font-family: monospace; white-space: pre-wrap; font-size: 0.85em;">Connexion au flux...</div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block localscript %}
<script>
(function() {
    const analysisId = {{ analysis.id }};
    const consoleEl = document.getElementById('console-output');
    const btnStop = document.getElementById('btn-stop');
    const statusBadge = document.getElementById('status-badge');
    let buffer = '';

    function esc(str) {
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
    }

    function parseLine(line) {
        if (line.startsWith('TITLE:')) {
            return '<h5 class="text-info mt-2 mb-1">' + esc(line.substring(6)) + '</h5>';
        }
        if (line.startsWith('SITE:')) {
            return '<div class="text-muted mb-1"><i class="fa-solid fa-globe"></i> ' + esc(line.substring(5)) + '</div>';
        }
        if (line.startsWith('PAGES:')) {
            return '<div class="text-muted mb-2">' + esc(line.substring(6)) + ' page(s) à analyser</div>';
        }
        if (line.startsWith('STEP:')) {
            return '<div class="text-warning mt-2"><span class="spinner-border spinner-border-sm"></span> ' + esc(line.substring(5)) + '</div>';
        }
        if (line.startsWith('DONE:')) {
            return '<div class="text-success fw-bold mt-2"><i class="fa-solid fa-check-circle"></i> ' + esc(line.substring(5)) + '</div>';
        }
        if (line.startsWith('WARN:')) {
            return '<div class="text-warning mt-2"><i class="fa-solid fa-triangle-exclamation"></i> ' + esc(line.substring(5)) + '</div>';
        }
        if (line.startsWith('ERROR:')) {
            return '<div class="text-danger fw-bold mt-2"><i class="fa-solid fa-xmark-circle"></i> ' + esc(line.substring(6)) + '</div>';
        }
        if (line.startsWith('INFO:')) {
            return '<div class="text-info">' + esc(line.substring(5)) + '</div>';
        }
        if (line.startsWith('PAGE_START:')) {
            const parts = line.substring(11).split(':');
            const num = parts[0];
            const total = parts[1];
            const url = parts.slice(2).join(':');
            return '<div class="mt-2 border-top border-secondary pt-2"><span class="text-muted">[' + num + '/' + total + ']</span> <strong>' + esc(url) + '</strong></div>';
        }
        if (line.startsWith('LH:')) {
            const val = line.substring(3);
            if (val === 'NONE') {
                return '<div class="ms-3 text-muted">Lighthouse <span class="text-warning">ignoré</span></div>';
            }
            const [perf, a11y, seo] = val.split(':');
            return '<div class="ms-3">Lighthouse <span class="text-success">OK</span> <span class="text-muted">Perf=' + perf + '  A11y=' + a11y + '  SEO=' + seo + '</span></div>';
        }
        if (line.startsWith('RGAA:')) {
            const val = line.substring(5);
            if (val === 'NONE') {
                return '<div class="ms-3 text-muted">pa11y <span class="text-warning">ignoré</span></div>';
            }
            const [score, errors, warnings] = val.split(':');
            const scoreClass = parseInt(score) >= 90 ? 'text-success' : parseInt(score) >= 50 ? 'text-warning' : 'text-danger';
            return '<div class="ms-3">pa11y <span class="' + scoreClass + ' fw-bold">RGAA=' + score + '</span> <span class="text-muted">(' + errors + ' erreurs, ' + warnings + ' avertissements)</span></div>';
        }
        return '<div>' + esc(line) + '</div>';
    }

    function renderBuffer() {
        const lines = buffer.split('\n');
        buffer = lines.pop();
        let html = '';
        for (const line of lines) {
            if (line.trim()) html += parseLine(line);
        }
        consoleEl.innerHTML += html;
        consoleEl.scrollTop = consoleEl.scrollHeight;
    }

    function setStatus(label, color) {
        statusBadge.textContent = label;
        statusBadge.className = 'badge bg-' + color;
    }

    function showEndButtons() {
        let html = '<div class="mt-3 pt-3 border-top border-secondary">';
        html += '<a href="{{ path("audit_analysis", {id: analysis.id}) }}" class="btn btn-primary btn-lg me-2"><i class="fa-solid fa-chart-line"></i> Voir les résultats</a>';
        html += '<a href="{{ path("audit_analysis_ai", {id: analysis.id}) }}" class="btn btn-success btn-lg me-2"><i class="fa-solid fa-robot"></i> Lancer la synthèse IA</a>';
        html += '<a href="{{ path("audit_site", {id: site.id}) }}" class="btn btn-outline-secondary btn-lg"><i class="fa-solid fa-arrow-left"></i> Retour au site</a>';
        html += '</div>';
        consoleEl.innerHTML += html;
        consoleEl.scrollTop = consoleEl.scrollHeight;
    }

    window.stopAnalysis = async function() {
        btnStop.disabled = true;
        btnStop.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Arrêt...';
        try {
            await fetch('{{ path("audit_stream_stop", {type: "analysis", id: analysis.id}) }}', { method: 'POST' });
        } catch (e) {}
        consoleEl.innerHTML += '<div class="text-warning fw-bold mt-2"><i class="fa-solid fa-stop"></i> Arrêt demandé</div>';
    };

    (async function() {
        try {
            btnStop.style.display = 'inline-block';
            setStatus('RGAA en cours...', 'warning');
            const response = await fetch('{{ path("audit_stream_rgaa", {id: analysis.id}) }}');

            if (!response.ok) {
                consoleEl.innerHTML += '<div class="text-danger">Erreur HTTP ' + response.status + '</div>';
                setStatus('Erreur', 'danger');
                return;
            }

            if (!response.body) {
                consoleEl.innerHTML += '<div class="text-danger">Streaming non supporté.</div>';
                return;
            }

            const reader = response.body.getReader();
            const decoder = new TextDecoder();

            while (true) {
                const { value, done } = await reader.read();
                if (done) break;
                buffer += decoder.decode(value, { stream: true });
                renderBuffer();
            }

            if (buffer.trim()) {
                consoleEl.innerHTML += parseLine(buffer);
                buffer = '';
            }

            btnStop.style.display = 'none';
            setStatus('RGAA terminé', 'success');
            showEndButtons();

        } catch (error) {
            consoleEl.innerHTML += '<div class="text-danger fw-bold">Erreur : ' + esc(error.message) + '</div>';
            setStatus('Erreur', 'danger');
        }
    })();
})();
</script>
{% endblock %}
